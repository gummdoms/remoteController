{
  "dependencies": {
    "@hensm/ddcci": "^0.1.0",
    "async": "^3.2.5",
    "body-parser": "^1.20.2",
    "bootstrap-icons": "^1.11.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jquery": "^3.7.1",
    "loudness": "^0.4.2",
    "multer": "^1.4.5-lts.2",
    "node-abi": "^4.2.0",
    "nodemon": "^3.1.3",
    "normalize.css": "^8.0.1",
    "open": "^10.1.0",
    "robotjs": "^0.6.0",
    "sqlite3": "^5.1.7",
    "sweetalert2": "^11.11.0",
    "win-audio": "^3.0.3"
  },
  "devDependencies": {
    "electron": "^30.0.0-alpha.1",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "name": "remotecontrollers",
  "version": "1.0.3",
  "main": "app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "electron-builder",
    "build:native": "cd modules && npm install",
    "rebuild:native": "cd modules && npm run rebuild",
    "build:sass": "sass static/sass/index.view.scss static/css/index.view.css",
    "watch:sass": "sass static/sass/index.view.scss static/css/index.view.css --watch",
    "test:mouse": "node modules/examples.js",
    "setup": "npm install && npm run build:native && npm run build:sass"
  },
  "author": "Damar Narváez Martínez",
  "license": "ISC",
  "description": "Software para control remoto de pantalla",
  "build": {
    "appId": "com.bjrsoftware.remotecontrollers",
    "productName": "Remote Controllers",
    "copyright": "Copyright © 2024 BJRSOFTWARE",
    "win": {
      "icon": "assets/icon.ico",
      "publisherName": "BJRSOFTWARE",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Remote Controllers",
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true
    }
  }
}