{
  "name": "remotecontrollers",
  "version": "1.0.6",
  "main": "app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "start:prod": "CLOUD_SERVER_URL=https://remote-controller.bjrsoftware.uk electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:linux:pacman": "electron-builder --linux pacman",
    "dist:arch:pkg": "bash distros/archlinux/build-package.sh",
    "dist:arch:publish": "bash distros/archlinux/publish-datalake.sh",
    "dist:arch:upload": "bash distros/archlinux/upload-datalake.sh",
    "dist:arch:release": "bash distros/archlinux/release.sh",
    "dist:release:upload": "node scripts/upload-release-assets.js",
    "dist:release:upload:ci": "node scripts/upload-ci-assets.js",
    "postinstall": "electron-builder install-app-deps",
    "build:native": "cd modules && npm install && cd .. && electron-builder install-app-deps",
    "rebuild:native": "cd modules && npm run rebuild",
    "rebuild:electron": "electron-builder install-app-deps",
    "build:sass": "sass static/sass/index.view.scss static/css/index.view.css",
    "watch:sass": "sass static/sass/index.view.scss static/css/index.view.css --watch",
    "test:mouse": "node modules/examples.js",
    "setup": "npm install && npm run build:native && npm run build:sass"
  },
  "author": {
    "name": "Damar Narváez Martínez",
    "email": "damar23nnm@gmail.com"
  },
  "homepage": "https://remote-controller.bjrsoftware.uk/",
  "bugs": {
    "url": "https://remote-controller.bjrsoftware.uk/",
    "email": "damar23nnm@gmail.com"
  },
  "license": "ISC",
  "description": "Control remoto seguro de tu PC desde la web o el móvil (BJRSoftware)",
  "config": {
    "cloudUrl": "https://remote-controller.bjrsoftware.uk",
    "releasesUrl": "https://datalake.dambra-os.com/public/remote-controller/releases/arch/x86_64",
    "githubReleasesUrl": "https://github.com/gummdoms/remoteController/releases"
  },
  "build": {
    "appId": "com.bjrsoftware.remotecontrollers",
    "productName": "Remote Controllers",
    "copyright": "Copyright © 2024-2026 BJR Software",
    "win": {
      "icon": "assets/icon.ico",
      "legalTrademarks": "BJRSOFTWARE",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Utility",
      "maintainer": "Damar Narváez Martínez <damar23nnm@gmail.com>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Remote Controllers",
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true
    }
  },
  "dependencies": {
    "async": "^3.2.6",
    "body-parser": "^2.2.0",
    "bootstrap-icons": "^1.13.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jquery": "^3.7.1",
    "loudness": "^0.4.2",
    "multer": "^2.0.2",
    "node-abi": "^4.14.0",
    "node-addon-api": "^7.1.1",
    "nodemon": "^3.1.10",
    "normalize.css": "^8.0.1",
    "open": "^10.2.0",
    "qrcode": "^1.5.4",
    "sqlite3": "^5.1.7",
    "sweetalert2": "^11.26.1",
    "ws": "^8.21.0"
  },
  "optionalDependencies": {
    "@hensm/ddcci": "^0.1.0",
    "robotjs": "^0.6.0"
  },
  "overrides": {
    "@hensm/ddcci": {
      "node-addon-api": "^7.1.1"
    }
  },
  "devDependencies": {
    "electron": "^38.2.2",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "sass": "^1.94.0"
  }
}
